@page "/inbox"
@using Microsoft.AspNetCore.SignalR.Client
@implements IAsyncDisposable
@inject NavigationManager NavigationManager
@inject AuthStateService AuthStateService
@inject HttpClient Http

<PageTitle>Inbox - WhatsApp SaaS</PageTitle>

<div class="container-fluid px-0" style="height: calc(100vh - 56px);">
    <div class="row g-0 h-100">
        <!-- Sidebar: Contact/Conversation List -->
        <div class="col-md-3 border-end d-flex flex-column bg-white">
            <div class="p-3 border-bottom d-flex justify-content-between align-items-center">
                <h6 class="mb-0 fw-bold"><i class="bi bi-chat-dots me-2 text-success"></i>Conversas</h6>
                <div class="btn-group btn-group-sm">
                    <button class="btn @(_statusFilter == null ? "btn-success" : "btn-outline-secondary") btn-sm" @onclick="FilterAll">Todas</button>
                    <button class="btn @(_statusFilter == "New" ? "btn-success" : "btn-outline-secondary") btn-sm" @onclick="FilterNew">Novas</button>
                    <button class="btn @(_statusFilter == "InProgress" ? "btn-success" : "btn-outline-secondary") btn-sm" @onclick="FilterInProgress">Em Atend.</button>
                </div>
            </div>
            <div class="overflow-auto flex-grow-1">
                @if (_isLoadingConversations)
                {
                    <div class="text-center p-4">
                        <div class="spinner-border spinner-border-sm text-success"></div>
                    </div>
                }
                else if (!_conversations.Any())
                {
                    <div class="text-center p-4 text-muted">
                        <i class="bi bi-inbox fs-2"></i>
                        <p class="mt-2 small">Nenhuma conversa</p>
                    </div>
                }
                else
                {
                    @foreach (var conv in _filteredConversations)
                    {
                        <div class="p-3 border-bottom cursor-pointer @(conv.Id == _selectedConversationId ? "bg-success bg-opacity-10" : "")"
                             style="cursor: pointer;" @onclick="() => SelectConversation(conv)">
                            <div class="d-flex justify-content-between">
                                <strong class="text-truncate">@conv.ContactName</strong>
                                <small class="text-muted flex-shrink-0 ms-2">
                                    @(conv.LastMessageAt?.ToString("HH:mm") ?? "")
                                </small>
                            </div>
                            <div class="text-truncate small text-muted">@conv.LastMessage</div>
                            <div class="mt-1">
                                @{
                                    var badge = conv.Status switch
                                    {
                                        "New" => ("bg-primary", "Nova"),
                                        "InProgress" => ("bg-warning text-dark", "Em Atendimento"),
                                        "Finished" => ("bg-secondary", "Finalizada"),
                                        _ => ("bg-light text-dark", conv.Status)
                                    };
                                }
                                <span class="badge @badge.Item1" style="font-size: 0.65rem;">@badge.Item2</span>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Main Content: Chat Window -->
        <div class="col-md-6 d-flex flex-column bg-light">
            @if (_selectedConversation == null)
            {
                <div class="flex-grow-1 d-flex align-items-center justify-content-center text-muted">
                    <div class="text-center">
                        <i class="bi bi-chat-square-dots fs-1 text-success opacity-50"></i>
                        <p class="mt-3">Selecione uma conversa para começar</p>
                    </div>
                </div>
            }
            else
            {
                <div class="p-3 bg-white border-bottom d-flex justify-content-between align-items-center shadow-sm">
                    <div>
                        <h6 class="mb-0 fw-bold">@_selectedConversation.ContactName</h6>
                        <small class="text-muted">@_selectedConversation.ContactPhone</small>
                    </div>
                    <div class="d-flex gap-2">
                        <select class="form-select form-select-sm" style="width: auto;" @onchange="UpdateStatus">
                            <option value="New" selected="@(_selectedConversation.Status == "New")">Nova</option>
                            <option value="InProgress" selected="@(_selectedConversation.Status == "InProgress")">Em Atendimento</option>
                            <option value="Finished" selected="@(_selectedConversation.Status == "Finished")">Finalizada</option>
                        </select>
                    </div>
                </div>

                <div class="flex-grow-1 p-3 overflow-auto" style="max-height: calc(100vh - 200px);">
                    @foreach (var msg in _messages)
                    {
                        <div class="d-flex @(msg.IsFromContact ? "justify-content-start" : "justify-content-end") mb-2">
                            <div class="p-2 px-3 rounded-3 @(msg.IsFromContact ? "bg-white shadow-sm" : "bg-success text-white")" style="max-width: 70%;">
                                <div>@msg.Content</div>
                                <div class="text-end mt-1" style="font-size: 0.7rem; opacity: 0.7;">@msg.SentAt.ToString("HH:mm")</div>
                            </div>
                        </div>
                    }
                </div>

                <div class="p-3 bg-white border-top">
                    <div class="input-group">
                        <input type="text" class="form-control rounded-start" placeholder="Digite uma mensagem..."
                               @bind="_newMessage" @onkeyup="HandleKeyUp" />
                        <button class="btn btn-success" @onclick="SendMessage" disabled="@_isSending">
                            @if (_isSending)
                            {
                                <span class="spinner-border spinner-border-sm"></span>
                            }
                            else
                            {
                                <i class="bi bi-send-fill"></i>
                            }
                        </button>
                    </div>
                    @if (_quickResponses.Any())
                    {
                        <div class="mt-2 d-flex flex-wrap gap-1">
                            @foreach (var qr in _quickResponses)
                            {
                                <button class="btn btn-outline-secondary btn-sm" @onclick="() => UseQuickResponse(qr.Content)">
                                    <i class="bi bi-lightning me-1"></i>@qr.Shortcut
                                </button>
                            }
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Right Sidebar: Contact Details -->
        <div class="col-md-3 border-start p-3 bg-white overflow-auto">
            <h6 class="fw-bold mb-3"><i class="bi bi-person-circle me-2 text-primary"></i>Detalhes do Contato</h6>
            @if (_selectedConversation != null)
            {
                <div class="mb-3">
                    <div class="fw-semibold">@_selectedConversation.ContactName</div>
                    <div class="text-muted small"><i class="bi bi-telephone me-1"></i>@_selectedConversation.ContactPhone</div>
                </div>
                <hr />
                <div class="mb-3">
                    <label class="form-label small fw-semibold text-muted">ATENDENTE</label>
                    <select class="form-select form-select-sm" @onchange="AssignToAttendant">
                        <option value="">Não atribuído</option>
                        @foreach (var user in _users)
                        {
                            <option value="@user.Id" selected="@(_selectedConversation.AssignedUserId?.ToString() == user.Id.ToString())">@user.Name</option>
                        }
                    </select>
                </div>
                <hr />
                <div>
                    <label class="form-label small fw-semibold text-muted">AGENDAMENTOS</label>
                    <a href="/appointments" class="btn btn-outline-primary btn-sm w-100">
                        <i class="bi bi-calendar-plus me-1"></i>Ver Agendamentos
                    </a>
                </div>
            }
            else
            {
                <p class="text-muted small">Selecione uma conversa</p>
            }
        </div>
    </div>
</div>

@code {
    private List<ConversationDto> _conversations = new();
    private List<ConversationDto> _filteredConversations = new();
    private List<MessageDto> _messages = new();
    private List<QuickResponseDto> _quickResponses = new();
    private List<UserDto> _users = new();
    private ConversationDto? _selectedConversation;
    private Guid _selectedConversationId;
    private string? _statusFilter;
    private string _newMessage = "";
    private bool _isLoadingConversations = true;
    private bool _isSending;
    private HubConnection? _hubConnection;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthStateService.IsAuthenticated)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        Http.DefaultRequestHeaders.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", AuthStateService.Token);

        await LoadConversations();
        await LoadQuickResponses();
        await LoadUsers();
        await SetupSignalR();
    }

    private async Task LoadConversations()
    {
        _isLoadingConversations = true;
        try
        {
            _conversations = await Http.GetFromJsonAsync<List<ConversationDto>>("api/conversations") ?? new();
            FilterConversations(_statusFilter);
        }
        catch { }
        _isLoadingConversations = false;
    }

    private async Task LoadQuickResponses()
    {
        try
        {
            _quickResponses = await Http.GetFromJsonAsync<List<QuickResponseDto>>("api/quickresponses") ?? new();
        }
        catch { }
    }

    private async Task LoadUsers()
    {
        try
        {
            var companyId = AuthStateService.CompanyId;
            _users = await Http.GetFromJsonAsync<List<UserDto>>($"api/companies/{companyId}/users") ?? new();
        }
        catch { }
    }

    private void FilterAll() => FilterConversations(null);
    private void FilterNew() => FilterConversations("New");
    private void FilterInProgress() => FilterConversations("InProgress");

    private void FilterConversations(string? status)
    {
        _statusFilter = status;
        _filteredConversations = status == null
            ? _conversations
            : _conversations.Where(c => c.Status == status).ToList();
        StateHasChanged();
    }

    private async Task SelectConversation(ConversationDto conv)
    {
        _selectedConversation = conv;
        _selectedConversationId = conv.Id;
        _messages = new();
        
        try
        {
            _messages = await Http.GetFromJsonAsync<List<MessageDto>>($"api/conversations/{conv.Id}/messages") ?? new();
        }
        catch { }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_newMessage) || _selectedConversation == null) return;

        _isSending = true;
        var content = _newMessage;
        _newMessage = "";

        try
        {
            var response = await Http.PostAsJsonAsync(
                $"api/conversations/{_selectedConversation.Id}/messages",
                new SendMessageRequest { Content = content });

            if (response.IsSuccessStatusCode)
            {
                var msg = await response.Content.ReadFromJsonAsync<MessageDto>();
                if (msg != null) _messages.Add(msg);
            }
        }
        catch { }
        _isSending = false;
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SendMessage();
    }

    private void UseQuickResponse(string content)
    {
        _newMessage = content;
    }

    private async Task UpdateStatus(ChangeEventArgs e)
    {
        if (_selectedConversation == null) return;
        var status = e.Value?.ToString() ?? "";
        try
        {
            await Http.PutAsJsonAsync($"api/conversations/{_selectedConversation.Id}/status",
                new UpdateConversationStatusRequest { Status = status });
            _selectedConversation.Status = status;
            await LoadConversations();
        }
        catch { }
    }

    private async Task AssignToAttendant(ChangeEventArgs e)
    {
        if (_selectedConversation == null) return;
        Guid? userId = null;
        if (Guid.TryParse(e.Value?.ToString(), out var parsed)) userId = parsed;

        try
        {
            await Http.PutAsJsonAsync($"api/conversations/{_selectedConversation.Id}/assign",
                new AssignConversationRequest { UserId = userId });
            _selectedConversation.AssignedUserId = userId;
        }
        catch { }
    }

    private async Task SetupSignalR()
    {
        try
        {
            _hubConnection = new HubConnectionBuilder()
                .WithUrl(NavigationManager.ToAbsoluteUri("/chathub"), options =>
                {
                    options.AccessTokenProvider = () => Task.FromResult<string?>(AuthStateService.Token);
                })
                .Build();

            _hubConnection.On<MessageDto>("ReceiveMessage", (message) =>
            {
                if (_selectedConversation != null && message.ConversationId == _selectedConversation.Id)
                {
                    _messages.Add(message);
                }
                InvokeAsync(StateHasChanged);
            });

            await _hubConnection.StartAsync();

            if (_hubConnection.State == HubConnectionState.Connected)
            {
                await _hubConnection.SendAsync("JoinCompanyGroup", AuthStateService.CompanyId.ToString());
            }
        }
        catch { /* SignalR connection to API hub - ok to fail if API not running */ }
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection != null)
            await _hubConnection.DisposeAsync();
    }
}

