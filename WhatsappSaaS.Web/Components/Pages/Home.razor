@page "/"
@inject AuthStateService AuthStateService
@inject HttpClient Http
@inject NavigationManager NavigationManager

<PageTitle>Dashboard - WhatsApp SaaS</PageTitle>

@if (!AuthStateService.IsAuthenticated)
{
    <div class="container mt-5 text-center">
        <i class="bi bi-whatsapp text-success" style="font-size: 4rem;"></i>
        <h2 class="mt-3">WhatsApp SaaS</h2>
        <p class="text-muted">Sistema de Gestão de Atendimento</p>
        <a href="/login" class="btn btn-success btn-lg mt-2">
            <i class="bi bi-box-arrow-in-right me-2"></i>Entrar
        </a>
    </div>
}
else
{
    <div class="container-fluid px-4 py-3">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h4 class="mb-0 fw-bold">Dashboard</h4>
                <p class="text-muted small mb-0">Bem-vindo, @AuthStateService.UserName</p>
            </div>
            <span class="badge bg-success fs-6"><i class="bi bi-whatsapp me-1"></i>WhatsApp SaaS</span>
        </div>

        @if (_metrics == null)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-success"></div>
                <p class="mt-2 text-muted">Carregando métricas...</p>
            </div>
        }
        else
        {
            <!-- Metric Cards -->
            <div class="row g-3 mb-4">
                <div class="col-sm-6 col-xl-3">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex align-items-center">
                                <div class="flex-shrink-0">
                                    <div class="rounded-circle bg-success bg-opacity-10 p-3">
                                        <i class="bi bi-chat-dots text-success fs-4"></i>
                                    </div>
                                </div>
                                <div class="ms-3">
                                    <div class="fw-bold fs-3">@_metrics.TotalMessages</div>
                                    <div class="text-muted small">Total de Mensagens</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-xl-3">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex align-items-center">
                                <div class="flex-shrink-0">
                                    <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                                        <i class="bi bi-people text-primary fs-4"></i>
                                    </div>
                                </div>
                                <div class="ms-3">
                                    <div class="fw-bold fs-3">@_metrics.TotalLeads</div>
                                    <div class="text-muted small">Total de Leads</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-xl-3">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex align-items-center">
                                <div class="flex-shrink-0">
                                    <div class="rounded-circle bg-warning bg-opacity-10 p-3">
                                        <i class="bi bi-hourglass-split text-warning fs-4"></i>
                                    </div>
                                </div>
                                <div class="ms-3">
                                    <div class="fw-bold fs-3">@_metrics.ActiveConversations</div>
                                    <div class="text-muted small">Em Atendimento</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-xl-3">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex align-items-center">
                                <div class="flex-shrink-0">
                                    <div class="rounded-circle bg-info bg-opacity-10 p-3">
                                        <i class="bi bi-check2-all text-info fs-4"></i>
                                    </div>
                                </div>
                                <div class="ms-3">
                                    <div class="fw-bold fs-3">@_metrics.FinishedConversations</div>
                                    <div class="text-muted small">Finalizadas</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Attendant performance -->
            <div class="row g-3">
                <div class="col-lg-6">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-transparent border-0 py-3">
                            <h6 class="mb-0 fw-bold"><i class="bi bi-bar-chart me-2 text-success"></i>Volume de Conversas (7 dias)</h6>
                        </div>
                        <div class="card-body">
                            @if (_metrics.ConversationVolume.Any())
                            {
                                <div class="table-responsive">
                                    <table class="table table-sm table-hover">
                                        <thead>
                                            <tr><th>Período</th><th>Conversas</th></tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var vol in _metrics.ConversationVolume)
                                            {
                                                <tr>
                                                    <td>@vol.Period</td>
                                                    <td><span class="badge bg-success">@vol.Count</span></td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <p class="text-muted text-center py-3">Nenhuma conversa registrada</p>
                            }
                        </div>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-transparent border-0 py-3">
                            <h6 class="mb-0 fw-bold"><i class="bi bi-person-badge me-2 text-primary"></i>Desempenho por Atendente</h6>
                        </div>
                        <div class="card-body">
                            @if (_metrics.AttendantPerformance.Any())
                            {
                                <div class="table-responsive">
                                    <table class="table table-sm table-hover">
                                        <thead>
                                            <tr><th>Atendente</th><th>Conversas</th><th>Mensagens</th></tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var perf in _metrics.AttendantPerformance)
                                            {
                                                <tr>
                                                    <td>@perf.AttendantName</td>
                                                    <td>@perf.ConversationsHandled</td>
                                                    <td>@perf.MessagesExchanged</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <p class="text-muted text-center py-3">Nenhum atendimento registrado</p>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="row g-3 mt-2">
                <div class="col-12">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-transparent border-0 py-3">
                            <h6 class="mb-0 fw-bold"><i class="bi bi-lightning me-2 text-warning"></i>Ações Rápidas</h6>
                        </div>
                        <div class="card-body">
                            <div class="d-flex flex-wrap gap-2">
                                <a href="/inbox" class="btn btn-outline-success">
                                    <i class="bi bi-chat-dots me-2"></i>Abrir Inbox
                                </a>
                                <a href="/contacts" class="btn btn-outline-primary">
                                    <i class="bi bi-person-plus me-2"></i>Novo Contato
                                </a>
                                <a href="/chatbot" class="btn btn-outline-secondary">
                                    <i class="bi bi-robot me-2"></i>Configurar Chatbot
                                </a>
                                <a href="/quick-responses" class="btn btn-outline-warning">
                                    <i class="bi bi-lightning me-2"></i>Respostas Rápidas
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private DashboardMetricsDto? _metrics;

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateService.IsAuthenticated)
        {
            await LoadMetrics();
        }
    }

    private async Task LoadMetrics()
    {
        try
        {
            Http.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", AuthStateService.Token);
            _metrics = await Http.GetFromJsonAsync<DashboardMetricsDto>("api/dashboard/metrics");
        }
        catch
        {
            // API might not be available, use empty metrics
            _metrics = new DashboardMetricsDto();
        }
    }
}

