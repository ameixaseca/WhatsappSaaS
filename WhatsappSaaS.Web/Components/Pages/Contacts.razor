@page "/contacts"
@inject AuthStateService AuthStateService
@inject HttpClient Http
@inject NavigationManager NavigationManager

<PageTitle>Contatos - WhatsApp SaaS</PageTitle>

<div class="container-fluid px-4 py-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="mb-0 fw-bold"><i class="bi bi-people me-2 text-primary"></i>CRM - Contatos</h5>
        <button class="btn btn-primary btn-sm" @onclick="ShowCreateModal">
            <i class="bi bi-person-plus me-1"></i>Novo Contato
        </button>
    </div>

    @if (_isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                @if (!_contacts.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-people fs-1 opacity-50"></i>
                        <p class="mt-3">Nenhum contato cadastrado</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Nome</th>
                                    <th>Telefone</th>
                                    <th>Etiquetas</th>
                                    <th>Criado em</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var contact in _contacts)
                                {
                                    <tr>
                                        <td class="fw-semibold">@contact.Name</td>
                                        <td><i class="bi bi-telephone me-1 text-muted"></i>@contact.PhoneNumber</td>
                                        <td>
                                            @foreach (var tag in contact.Tags)
                                            {
                                                <span class="badge me-1" style="background-color: @tag.Color;">@tag.Name</span>
                                            }
                                        </td>
                                        <td class="text-muted small">@contact.CreatedAt.ToString("dd/MM/yyyy")</td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => EditContact(contact)">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteContact(contact.Id)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>

<!-- Create/Edit Modal -->
@if (_showModal)
{
    <div class="modal show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editingContact == null ? "Novo Contato" : "Editar Contato")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Nome *</label>
                        <input class="form-control" @bind="_formName" placeholder="Nome do contato" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Telefone *</label>
                        <input class="form-control" @bind="_formPhone" placeholder="+55 11 99999-0000" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Observações</label>
                        <textarea class="form-control" @bind="_formNotes" rows="3" placeholder="Observações internas..."></textarea>
                    </div>
                    @if (!string.IsNullOrEmpty(_formError))
                    {
                        <div class="alert alert-danger py-2">@_formError</div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModal">Cancelar</button>
                    <button class="btn btn-primary" @onclick="SaveContact" disabled="@_isSaving">
                        @if (_isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Salvar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<ContactDto> _contacts = new();
    private bool _isLoading = true;
    private bool _showModal;
    private bool _isSaving;
    private ContactDto? _editingContact;
    private string _formName = "";
    private string _formPhone = "";
    private string _formNotes = "";
    private string? _formError;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthStateService.IsAuthenticated) { NavigationManager.NavigateTo("/login"); return; }
        Http.DefaultRequestHeaders.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", AuthStateService.Token);
        await LoadContacts();
    }

    private async Task LoadContacts()
    {
        _isLoading = true;
        try { _contacts = await Http.GetFromJsonAsync<List<ContactDto>>("api/contacts") ?? new(); }
        catch { }
        _isLoading = false;
    }

    private void ShowCreateModal()
    {
        _editingContact = null;
        _formName = _formPhone = _formNotes = _formError = "";
        _showModal = true;
    }

    private void EditContact(ContactDto contact)
    {
        _editingContact = contact;
        _formName = contact.Name;
        _formPhone = contact.PhoneNumber;
        _formNotes = contact.Notes;
        _formError = null;
        _showModal = true;
    }

    private void CloseModal() => _showModal = false;

    private async Task SaveContact()
    {
        if (string.IsNullOrWhiteSpace(_formName) || string.IsNullOrWhiteSpace(_formPhone))
        {
            _formError = "Nome e telefone são obrigatórios.";
            return;
        }

        _isSaving = true;
        _formError = null;
        try
        {
            if (_editingContact == null)
            {
                var resp = await Http.PostAsJsonAsync("api/contacts",
                    new CreateContactRequest { Name = _formName, PhoneNumber = _formPhone, Notes = _formNotes });
                if (!resp.IsSuccessStatusCode) _formError = "Erro ao criar contato.";
            }
            else
            {
                var resp = await Http.PutAsJsonAsync($"api/contacts/{_editingContact.Id}",
                    new UpdateContactRequest { Name = _formName, PhoneNumber = _formPhone, Notes = _formNotes });
                if (!resp.IsSuccessStatusCode) _formError = "Erro ao atualizar contato.";
            }

            if (_formError == null)
            {
                _showModal = false;
                await LoadContacts();
            }
        }
        catch { _formError = "Erro de comunicação com o servidor."; }
        _isSaving = false;
    }

    private async Task DeleteContact(Guid id)
    {
        try
        {
            await Http.DeleteAsync($"api/contacts/{id}");
            await LoadContacts();
        }
        catch { }
    }
}
