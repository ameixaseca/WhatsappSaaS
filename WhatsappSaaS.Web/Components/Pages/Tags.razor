@page "/tags"
@inject AuthStateService AuthStateService
@inject HttpClient Http
@inject NavigationManager NavigationManager

<PageTitle>Etiquetas - WhatsApp SaaS</PageTitle>

<div class="container-fluid px-4 py-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="mb-0 fw-bold"><i class="bi bi-tags me-2 text-warning"></i>Etiquetas</h5>
        <button class="btn btn-warning btn-sm" @onclick="ShowCreateModal">
            <i class="bi bi-plus me-1"></i>Nova Etiqueta
        </button>
    </div>

    @if (_isLoading)
    {
        <div class="text-center py-5"><div class="spinner-border text-warning"></div></div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var tag in _tags)
            {
                <div class="col-sm-6 col-md-4 col-lg-3">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body d-flex align-items-center justify-content-between">
                            <span class="badge fs-6 px-3 py-2" style="background-color: @tag.Color;">@tag.Name</span>
                            <div>
                                <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => EditTag(tag)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteTag(tag.Id)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
            @if (!_tags.Any())
            {
                <div class="col-12 text-center py-5 text-muted">
                    <i class="bi bi-tags fs-1 opacity-50"></i>
                    <p class="mt-3">Nenhuma etiqueta cadastrada</p>
                </div>
            }
        </div>
    }
</div>

@if (_showModal)
{
    <div class="modal show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editingTag == null ? "Nova Etiqueta" : "Editar Etiqueta")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Nome *</label>
                        <input class="form-control" @bind="_formName" placeholder="Ex: Novo Lead" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Cor</label>
                        <input type="color" class="form-control form-control-color" @bind="_formColor" />
                    </div>
                    <div class="mt-2">
                        <span class="badge fs-6 px-3 py-2" style="background-color: @_formColor;">@_formName</span>
                    </div>
                    @if (!string.IsNullOrEmpty(_formError)) { <div class="alert alert-danger py-2 mt-3">@_formError</div> }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModal">Cancelar</button>
                    <button class="btn btn-warning" @onclick="SaveTag" disabled="@_isSaving">
                        @if (_isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Salvar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<TagDto> _tags = new();
    private bool _isLoading = true;
    private bool _showModal;
    private bool _isSaving;
    private TagDto? _editingTag;
    private string _formName = "";
    private string _formColor = "#28a745";
    private string? _formError;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthStateService.IsAuthenticated) { NavigationManager.NavigateTo("/login"); return; }
        Http.DefaultRequestHeaders.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", AuthStateService.Token);
        await LoadTags();
    }

    private async Task LoadTags()
    {
        _isLoading = true;
        try { _tags = await Http.GetFromJsonAsync<List<TagDto>>("api/tags") ?? new(); }
        catch { }
        _isLoading = false;
    }

    private void ShowCreateModal()
    {
        _editingTag = null;
        _formName = "";
        _formColor = "#28a745";
        _formError = null;
        _showModal = true;
    }

    private void EditTag(TagDto tag)
    {
        _editingTag = tag;
        _formName = tag.Name;
        _formColor = tag.Color;
        _formError = null;
        _showModal = true;
    }

    private void CloseModal() => _showModal = false;

    private async Task SaveTag()
    {
        if (string.IsNullOrWhiteSpace(_formName)) { _formError = "Nome é obrigatório."; return; }
        _isSaving = true;
        _formError = null;
        try
        {
            if (_editingTag == null)
            {
                var resp = await Http.PostAsJsonAsync("api/tags", new CreateTagRequest { Name = _formName, Color = _formColor });
                if (!resp.IsSuccessStatusCode) _formError = "Erro ao criar etiqueta.";
            }
            else
            {
                var resp = await Http.PutAsJsonAsync($"api/tags/{_editingTag.Id}", new UpdateTagRequest { Name = _formName, Color = _formColor });
                if (!resp.IsSuccessStatusCode) _formError = "Erro ao atualizar etiqueta.";
            }
            if (_formError == null) { _showModal = false; await LoadTags(); }
        }
        catch { _formError = "Erro de comunicação com o servidor."; }
        _isSaving = false;
    }

    private async Task DeleteTag(Guid id)
    {
        try { await Http.DeleteAsync($"api/tags/{id}"); await LoadTags(); }
        catch { }
    }
}
