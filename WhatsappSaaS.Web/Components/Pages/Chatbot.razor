@page "/chatbot"
@inject AuthStateService AuthStateService
@inject HttpClient Http
@inject NavigationManager NavigationManager

<PageTitle>Chatbot - WhatsApp SaaS</PageTitle>

<div class="container-fluid px-4 py-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h5 class="mb-0 fw-bold"><i class="bi bi-robot me-2 text-secondary"></i>Fluxos de Chatbot</h5>
            <p class="text-muted small mb-0">Configure automações de atendimento</p>
        </div>
        <button class="btn btn-secondary btn-sm" @onclick="ShowCreateModal">
            <i class="bi bi-plus me-1"></i>Novo Fluxo
        </button>
    </div>

    @if (_isLoading)
    {
        <div class="text-center py-5"><div class="spinner-border text-secondary"></div></div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var flow in _flows)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h6 class="card-title fw-bold mb-0">@flow.Name</h6>
                                <span class="badge @(flow.IsActive ? "bg-success" : "bg-secondary")">
                                    @(flow.IsActive ? "Ativo" : "Inativo")
                                </span>
                            </div>
                            <p class="text-muted small">@flow.Steps.Count etapa(s) configurada(s)</p>
                            <div class="mt-2">
                                @foreach (var step in flow.Steps.Take(3))
                                {
                                    <div class="d-flex align-items-center mb-1">
                                        <span class="badge bg-light text-dark me-2">@step.Order</span>
                                        <span class="small text-truncate">@step.Content</span>
                                    </div>
                                }
                                @if (flow.Steps.Count > 3)
                                {
                                    <span class="text-muted small">+ @(flow.Steps.Count - 3) etapas...</span>
                                }
                            </div>
                        </div>
                        <div class="card-footer bg-transparent border-top d-flex gap-2">
                            <button class="btn btn-sm @(flow.IsActive ? "btn-outline-warning" : "btn-outline-success") flex-grow-1"
                                    @onclick="() => ToggleFlow(flow.Id)">
                                <i class="bi @(flow.IsActive ? "bi-pause" : "bi-play") me-1"></i>
                                @(flow.IsActive ? "Pausar" : "Ativar")
                            </button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteFlow(flow.Id)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }
            @if (!_flows.Any())
            {
                <div class="col-12 text-center py-5 text-muted">
                    <i class="bi bi-robot fs-1 opacity-50"></i>
                    <p class="mt-3">Nenhum fluxo de chatbot configurado</p>
                    <p class="small">Crie fluxos automáticos para responder clientes</p>
                </div>
            }
        </div>
    }
</div>

@if (_showModal)
{
    <div class="modal show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Novo Fluxo de Chatbot</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Nome do Fluxo *</label>
                        <input class="form-control" @bind="_formName" placeholder="Ex: Atendimento Inicial" />
                    </div>
                    <div class="mb-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" @bind="_formIsActive" id="isActive" />
                            <label class="form-check-label" for="isActive">Ativar imediatamente</label>
                        </div>
                    </div>
                    <hr />
                    <h6 class="fw-bold">Etapas do Fluxo</h6>
                    @for (int i = 0; i < _formSteps.Count; i++)
                    {
                        var idx = i;
                        <div class="card mb-2">
                            <div class="card-body py-2">
                                <div class="row g-2 align-items-center">
                                    <div class="col-auto">
                                        <span class="badge bg-secondary">@(idx + 1)</span>
                                    </div>
                                    <div class="col">
                                        <input class="form-control form-control-sm" @bind="_formSteps[idx].Content"
                                               placeholder="Conteúdo da etapa..." />
                                    </div>
                                    <div class="col-auto">
                                        <select class="form-select form-select-sm" @bind="_formSteps[idx].Type">
                                            <option value="Response">Resposta</option>
                                            <option value="Question">Pergunta</option>
                                            <option value="Menu">Menu</option>
                                            <option value="TransferToHuman">Transferir para Humano</option>
                                        </select>
                                    </div>
                                    <div class="col-auto">
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveStep(idx)">
                                            <i class="bi bi-x"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    <button class="btn btn-outline-secondary btn-sm" @onclick="AddStep">
                        <i class="bi bi-plus me-1"></i>Adicionar Etapa
                    </button>
                    @if (!string.IsNullOrEmpty(_formError)) { <div class="alert alert-danger py-2 mt-3">@_formError</div> }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModal">Cancelar</button>
                    <button class="btn btn-primary" @onclick="SaveFlow" disabled="@_isSaving">
                        @if (_isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Salvar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<ChatbotFlowDto> _flows = new();
    private bool _isLoading = true;
    private bool _showModal;
    private bool _isSaving;
    private string _formName = "";
    private bool _formIsActive = true;
    private List<CreateFlowStepRequest> _formSteps = new();
    private string? _formError;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthStateService.IsAuthenticated) { NavigationManager.NavigateTo("/login"); return; }
        Http.DefaultRequestHeaders.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", AuthStateService.Token);
        await LoadFlows();
    }

    private async Task LoadFlows()
    {
        _isLoading = true;
        try { _flows = await Http.GetFromJsonAsync<List<ChatbotFlowDto>>("api/chatbot") ?? new(); }
        catch { }
        _isLoading = false;
    }

    private void ShowCreateModal()
    {
        _formName = "";
        _formIsActive = true;
        _formSteps = new() { new CreateFlowStepRequest { Content = "Olá! Como posso ajudar?", Type = "Response", Order = 1 } };
        _formError = null;
        _showModal = true;
    }

    private void CloseModal() => _showModal = false;
    private void AddStep() => _formSteps.Add(new CreateFlowStepRequest { Order = _formSteps.Count + 1, Type = "Response" });
    private void RemoveStep(int idx) => _formSteps.RemoveAt(idx);

    private async Task SaveFlow()
    {
        if (string.IsNullOrWhiteSpace(_formName)) { _formError = "Nome é obrigatório."; return; }
        _isSaving = true; _formError = null;
        try
        {
            var resp = await Http.PostAsJsonAsync("api/chatbot", new CreateChatbotFlowRequest
            {
                Name = _formName,
                IsActive = _formIsActive,
                Steps = _formSteps
            });
            if (resp.IsSuccessStatusCode) { _showModal = false; await LoadFlows(); }
            else _formError = "Erro ao criar fluxo.";
        }
        catch { _formError = "Erro de comunicação."; }
        _isSaving = false;
    }

    private async Task ToggleFlow(Guid id)
    {
        try { await Http.PutAsync($"api/chatbot/{id}/toggle", null); await LoadFlows(); }
        catch { }
    }

    private async Task DeleteFlow(Guid id)
    {
        try { await Http.DeleteAsync($"api/chatbot/{id}"); await LoadFlows(); }
        catch { }
    }
}
