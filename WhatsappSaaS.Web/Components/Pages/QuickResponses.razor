@page "/quick-responses"
@inject AuthStateService AuthStateService
@inject HttpClient Http
@inject NavigationManager NavigationManager

<PageTitle>Respostas Rápidas - WhatsApp SaaS</PageTitle>

<div class="container-fluid px-4 py-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h5 class="mb-0 fw-bold"><i class="bi bi-lightning me-2 text-warning"></i>Respostas Rápidas</h5>
            <p class="text-muted small mb-0">Digite o atalho no chat para inserir a mensagem automaticamente</p>
        </div>
        <button class="btn btn-warning btn-sm" @onclick="ShowCreateModal">
            <i class="bi bi-plus me-1"></i>Nova Resposta
        </button>
    </div>

    @if (_isLoading)
    {
        <div class="text-center py-5"><div class="spinner-border text-warning"></div></div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                @if (!_items.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-lightning fs-1 opacity-50"></i>
                        <p class="mt-3">Nenhuma resposta rápida cadastrada</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Atalho</th>
                                    <th>Mensagem</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _items)
                                {
                                    <tr>
                                        <td><span class="badge bg-dark font-monospace fs-6">@item.Shortcut</span></td>
                                        <td class="text-muted">@item.Content</td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => EditItem(item)">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteItem(item.Id)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>

@if (_showModal)
{
    <div class="modal show d-block" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editingItem == null ? "Nova Resposta Rápida" : "Editar Resposta Rápida")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Atalho *</label>
                        <input class="form-control font-monospace" @bind="_formShortcut" placeholder="/preco" />
                        <div class="form-text">Use / antes do atalho. Ex: /preco, /horario</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Mensagem *</label>
                        <textarea class="form-control" @bind="_formContent" rows="4" placeholder="Conteúdo da mensagem..."></textarea>
                    </div>
                    @if (!string.IsNullOrEmpty(_formError)) { <div class="alert alert-danger py-2">@_formError</div> }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModal">Cancelar</button>
                    <button class="btn btn-warning" @onclick="SaveItem" disabled="@_isSaving">
                        @if (_isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Salvar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<QuickResponseDto> _items = new();
    private bool _isLoading = true;
    private bool _showModal;
    private bool _isSaving;
    private QuickResponseDto? _editingItem;
    private string _formShortcut = "";
    private string _formContent = "";
    private string? _formError;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthStateService.IsAuthenticated) { NavigationManager.NavigateTo("/login"); return; }
        Http.DefaultRequestHeaders.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", AuthStateService.Token);
        await LoadItems();
    }

    private async Task LoadItems()
    {
        _isLoading = true;
        try { _items = await Http.GetFromJsonAsync<List<QuickResponseDto>>("api/quickresponses") ?? new(); }
        catch { }
        _isLoading = false;
    }

    private void ShowCreateModal() { _editingItem = null; _formShortcut = _formContent = ""; _formError = null; _showModal = true; }
    private void EditItem(QuickResponseDto item) { _editingItem = item; _formShortcut = item.Shortcut; _formContent = item.Content; _formError = null; _showModal = true; }
    private void CloseModal() => _showModal = false;

    private async Task SaveItem()
    {
        if (string.IsNullOrWhiteSpace(_formShortcut) || string.IsNullOrWhiteSpace(_formContent))
        { _formError = "Atalho e mensagem são obrigatórios."; return; }
        _isSaving = true; _formError = null;
        try
        {
            if (_editingItem == null)
            {
                var resp = await Http.PostAsJsonAsync("api/quickresponses", new CreateQuickResponseRequest { Shortcut = _formShortcut, Content = _formContent });
                if (!resp.IsSuccessStatusCode) _formError = "Erro ao criar resposta.";
            }
            else
            {
                var resp = await Http.PutAsJsonAsync($"api/quickresponses/{_editingItem.Id}", new UpdateQuickResponseRequest { Shortcut = _formShortcut, Content = _formContent });
                if (!resp.IsSuccessStatusCode) _formError = "Erro ao atualizar resposta.";
            }
            if (_formError == null) { _showModal = false; await LoadItems(); }
        }
        catch { _formError = "Erro de comunicação com o servidor."; }
        _isSaving = false;
    }

    private async Task DeleteItem(Guid id)
    {
        try { await Http.DeleteAsync($"api/quickresponses/{id}"); await LoadItems(); }
        catch { }
    }
}
